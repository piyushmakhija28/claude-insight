#!/bin/bash
# Update Status Reporter - Clarifies successful updates vs actual failures
#
# PURPOSE: Show clear, user-friendly update completion messages
# Distinguishes between:
#   - Successful updates with optional warnings (still works!)
#   - Actual failures (system broken)
#
# USAGE:
#   bash update-status success
#   bash update-status warning "optional warning message"
#   bash update-status failed "error message"

STATUS=$1
MESSAGE=${2:-""}

if [ "$STATUS" = "success" ]; then
    cat <<EOF
================================================================================
✅ UPDATE COMPLETED SUCCESSFULLY!
================================================================================

Version: v0.39.0 (IDE) + v4.8.0 (Hooks)

What was updated:
  ✓ hook-downloader.py        Updated to ~/.claude/scripts/
  ✓ post-update.sh            Repository-aware syncing (Unix)
  ✓ post-update.ps1           Repository-aware syncing (Windows)
  ✓ sync-insight              Quick sync convenience script
  ✓ sync-insight.bat          Quick sync convenience script (Windows)
  ✓ Selective sync functions  New repo-aware syncing

Features:
  ✓ Repository-aware detection
  ✓ Selective syncing (much faster!)
  ✓ Smart fallback mechanism
  ✓ Zero manual intervention

System Status: READY FOR USE
Next Update Check: 24 hours

================================================================================
EOF

elif [ "$STATUS" = "warning" ]; then
    cat <<EOF
================================================================================
✅ UPDATE COMPLETED SUCCESSFULLY!
================================================================================

Version: v0.39.0 (IDE) + v4.8.0 (Hooks)

⚠️  Note: Some optional features not available
   (Non-blocking - system still works perfectly!)

What was updated:
  ✓ hook-downloader.py        Updated to ~/.claude/scripts/
  ✓ core sync functions       All critical components working

System Status: OPERATIONAL
Optional Features: Some unavailable (doesn't affect core functionality)

$MESSAGE

Next Update Check: 24 hours

================================================================================
EOF

elif [ "$STATUS" = "failed" ]; then
    cat <<EOF
================================================================================
❌ UPDATE FAILED - ACTION REQUIRED
================================================================================

Version: v0.39.0 (IDE) + v4.8.0 (Hooks)

Error:
$MESSAGE

System Status: REQUIRES ATTENTION

What to do:
  1. Check your internet connection
  2. Try manual sync: python ~/.claude/scripts/hook-downloader.py sync-all
  3. If problem persists, check ~/.claude/scripts/hook-downloader.py exists

Support: Check logs at ~/.claude/memory/logs/

================================================================================
EOF

else
    echo "Usage: update-status [success|warning|failed] [optional message]"
    exit 1
fi
